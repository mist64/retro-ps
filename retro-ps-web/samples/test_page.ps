statusdict begin
/oldjt jobtimeout def
0 setjobtimeout
/D{def}def
/ED{exch D}D
/GS{gsave}D
/GR{grestore}D
/printeris product def
/minpagewidth 6.5 def
(HP LaserJet IID) product eq (HP LaserJet IIID) product eq or
{/resetduplextrue false def
duplexmode
{ /resetduplextrue true def
false setduplexmode
} if
} if
clippath pathbbox pop pop translate 
clippath pathbbox pop exch pop sub -72 div 
minpagewidth 
lt
{ 
clippath pathbbox exch 3 1 
roll pop pop 
sub -72 div 8.5 div dup 
scale
} if
/y 725 def
/x 280 def
.7 setlinewidth
/rj {dup stringwidth pop 0 exch sub 0 rmoveto show 12 0 rmoveto} def
/rjul {dup stringwidth pop 0 exch sub /x1 exch def 
-25 0 rmoveto x1 0 rlineto 0 5 rmoveto show stroke
} def
/cr {/y y 13.5 sub def x y moveto
} def
/tf {
{( (on)) show} 
{( (off)) show} ifelse
} def
/titlef {/Helvetica-Bold findfont 12 scalefont setfont} def
/mf {/Helvetica-Bold findfont 9 scalefont setfont} def
/sf {/Helvetica-Bold findfont 7 scalefont setfont} def
/str 32 string def
/sho {str cvs show} def
x y moveto
titlef
(TEST PAGE) 
dup stringwidth pop 2 div 0 exch sub 0 rmoveto 
show cr
mf
printeris 
dup stringwidth pop 2 div 0 exch sub 0 rmoveto
( printer)
dup stringwidth pop 2 div 0 exch sub 0 rmoveto
printeris show 
( printer) show cr
(Level 2 PostScript* Cartridge Plus) 
dup stringwidth pop 2 div 0 exch sub 0 rmoveto
(Level 2 PostScript)
show sf 0 3 rmoveto (*) show mf 0 -3 rmoveto
( Cartridge Plus) show cr
/y 665 def 
x y moveto
0 5 rmoveto
(OPERATOR/VARIABLE ) rj (PERSISTENT VALUE) show cr
/Helvetica findfont 9 scalefont setfont
(SYSTEM SETUP OPERATORS) rjul cr 
(Password: ) rj 0 checkpassword
{(0) show} {(not default value) show} 
ifelse 
cr
(Jam Recovery: ) rj currentpagedevice /ExitJamRecovery get dup sho tf cr
(Auto Continue: ) rj doautocontinue  dup sho tf cr
(Print Errors: ) rj doprinterrors  dup sho tf cr
(HP LaserJet III) printeris eq (HP LaserJet IIID) printeris eq or
(HP LaserJet IIIP) printeris eq or
{(RET: ) rj
currentpagedevice /PostRenderingEnhanceDetails get /REValue get dup sho 
dup 0 eq {( (Off))} if
dup 1 eq {( (Light))}if
dup 2 eq {( (Medium))}if
dup 3 eq {( (Dark))} if
show cr pop} if
(Start Page: ) rj dostartpage dup sho tf cr
(Left Margin: ) rj margins sho ( (1/300 inch increments)) show cr
(Top Margin: ) rj margins pop sho ( (1/300 inch increments)) show cr
(PostScript Page Count: ) rj pagecount sho cr
(HP LaserJet IID) printeris eq (HP LaserJet IIID) printeris eq or
{(Page Stack Order: ) rj pagestackorder dup sho 
{( (face-down))}{( (face-up))} ifelse show cr} if
(Optional Memory Installed: ) rj
currentsystemparams /RamSize get 
1048576 div 1 sub dup sho 
( Megabyte) show 1 gt {(s) show} if cr
save 
true setglobal 
vmstatus exch pop exch pop
(Global Virtual Memory: ) rj sho ( (maximum available)) sho cr
false setglobal 
vmstatus exch pop exch pop
(Local Virtual Memory: ) rj sho ( (maximum available)) sho 
restore cr cr 
(Maximum Size of Font Cache: ) rj currentsystemparams /MaxFontCache get dup sho cr
(Current Size of Font Cache: ) rj currentsystemparams /CurFontCache get dup sho cr
(Printer Name: ) rj str printername sho cr
(Product Name: ) rj printeris sho cr
(PostScript Code Version: ) rj version sho cr
(Device Specific Revision: ) rj revision sho cr
(Active Communications Channel: ) rj currentsystemparams /CurInputDevice get dup sho cr
cr 
(TIMEOUT OPERATORS) rjul cr
(Job Timeout: ) rj oldjt dup sho 
0 eq {( (no time limit)) show} {( (seconds)) show} ifelse cr
(Manual Feed Timeout: ) rj currentpagedevice /ManualFeedTimeout get dup sho 
0 eq {( (no time limit)) show} {( (seconds)) show} ifelse cr
(Wait Timeout: ) rj waittimeout dup sho 
0 eq {( (no time limit)) show} {( (seconds)) show} ifelse cr
cr 
printeris (HP LaserJet IID) eq printeris (HP LaserJet IIID) eq or
{(DUPLEX OPERATORS) rjul cr
(Duplex Mode: ) rj resetduplextrue dup sho tf cr
(Tumble Mode: ) rj defaulttumble dup sho
{( (bind short edge)) show} {( (bind long edge)) show} ifelse cr
cr} if
printeris (HP LaserJet IIID) eq printeris (HP LaserJet IID) eq or
printeris (HP LaserJet IIP) eq or printeris (HP LaserJet IIIP) eq or
{(TRAY SELECTION OPERATORS) rjul cr
(Paper Tray: ) rj defaultpapertray
dup 0 eq {	printeris (HP LaserJet IIP) eq
printeris (HP LaserJet IIIP) eq or {(0 (mp tray))}
{(0 (upper tray))} ifelse } if
dup 1 eq {(1 (lower tray))  } if
dup 2 eq {(2 (envelope feeder))  } if
show pop cr
(Tray Switch: ) rj currentpagedevice /TraySwitch get dup sho tf cr 
} if
